import { AxiosInstance, CreateAxiosDefaults } from 'axios';

interface NetworkClient {
    request<TReturn extends object>(options: {
        url: string;
        headers?: Record<string, string>;
    } & ({
        method: 'GET';
    } | {
        method: 'POST';
        body: string | object;
    })): Promise<TReturn>;
}
type RetrieveTransaction = {
    id: string;
    version: string;
    amount: number;
    uri: string;
    type: string;
    publicKey: string;
    operation: string;
    metadata?: string | null;
    asset: string;
};
type CommitTransaction = {
    id: string;
};
type PrepareAsset = {
    operation: "CREATE" | string;
    amount: number;
    signerPublicKey: string;
    signerPrivateKey: string;
    recipientPublicKey: string;
    asset: object;
};
type UpdateAsset = {
    id: string;
    operation?: string | null;
    amount?: number | null;
    signerPublicKey: string;
    signerPrivateKey: string;
    recipientPublicKey?: string | null;
    asset?: string | null;
};
type FilterKeys = {
    ownerPublicKey?: string | null;
    recipientPublicKey?: string | null;
};
type Keys = {
    publicKey: string;
    privateKey: string;
};
type WithData<T> = {
    data: T;
    errors?: object[];
};

/**
 * Write Me
 */
declare class AxiosClient implements NetworkClient {
    instance: AxiosInstance;
    constructor(options?: CreateAxiosDefaults);
    constructor(client: AxiosInstance);
    request<TReturn>({ url, method, body, headers }: {
        url: string;
        method: "GET" | "POST";
        body: string | object;
        headers?: Record<string, string>;
    }): Promise<TReturn>;
}

declare class FetchClient implements NetworkClient {
    commonOptions: Partial<RequestInit>;
    constructor(commonOptions?: Partial<RequestInit>);
    request<TReturn>({ url, method, body, headers }: {
        url: string;
        method: "GET" | "POST";
        body: string | object;
        headers?: Record<string, string>;
    }): Promise<TReturn>;
}

/**
 * See https://github.com/ResilientApp/ResilientDB-GraphQL/blob/main/app.py
 */
declare class ResilientDB {
    uri: string;
    client: NetworkClient;
    constructor(uri: string, client: NetworkClient);
    getTransaction(requestId: string): Promise<RetrieveTransaction>;
    getAllTransactions(): Promise<RetrieveTransaction[]>;
    getFilteredTransactions(filter?: FilterKeys): Promise<RetrieveTransaction[]>;
    postTransaction(transaction: PrepareAsset): Promise<CommitTransaction>;
    updateTransaction(transaction: UpdateAsset): Promise<RetrieveTransaction>;
    updateMultipleTransaction(transactions: UpdateAsset[]): Promise<RetrieveTransaction[]>;
    static generateKeys(): {
        publicKey: string;
        privateKey: string;
    };
}

export { AxiosClient, CommitTransaction, FetchClient, FilterKeys, Keys, NetworkClient, PrepareAsset, ResilientDB, RetrieveTransaction, UpdateAsset, WithData };
